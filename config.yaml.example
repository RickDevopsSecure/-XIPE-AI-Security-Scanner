engagement:
  id: "ENG-001"
  client_name: "Target Company"
  tester: "Your Name — Your Company"
  start_date: "2026-01-01"
  end_date: "2026-12-31"
  authorized_by: "Client Name / Authorization Reference"
  authorization_document: "authorization_letter.pdf"

scope:
  base_urls:
    - "https://your-target.com"
  credentials:
    api_key: ""
    bearer_token: ""
    user_email: ""
    user_password: ""
  endpoints:
    chat: "/api/v1/chat"
    rag_query: "/api/v1/query"
    documents: "/api/v1/documents"
    assistants: "/api/v1/assistants"
    health: "/health"

modules:
  web_security: true
  tls_transport: true
  js_analysis: true
  ai_security: true
  prompt_injection: true
  rag_tester: true
  agent_tester: true
  trustworthiness: true

testing:
  request_delay_seconds: 0.5
  max_requests_per_minute: 30
  timeout_seconds: 15
  retry_attempts: 2

alerting:
  min_severity_to_report: "LOW"

output:
  log_file: "output/pentest.log"
  json_results: "output/findings.json"
  pdf_report: "output/report.pdf"
  dashboard_port: 5001

aws:
  enabled: false
  region: "us-east-1"
  s3_bucket: ""
  ecs_cluster: ""

integrations:
  teams_webhook_url: ""
  slack_webhook_url: ""
